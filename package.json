{
  "name": "pi-superpowers-plus",
  "version": "0.4.1",
  "description": "Superpowers workflow skills adapted for pi",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "check": "biome check . && tsc --noEmit && vitest run",
    "hooks:install": "prek install --hook-type pre-commit --hook-type pre-push"
  },
  "license": "MIT",
  "author": "coctostan",
  "repository": {
    "type": "git",
    "url": "https://github.com/coctostan/pi-superpowers-plus.git"
  },
  "files": [
    "extensions/",
    "agents/",
    "skills/",
    "banner.jpg",
    "LICENSE",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "extensions/plan-tracker.ts",
      "extensions/workflow-monitor.ts",
      "extensions/pi-subagents-index.js",
      "extensions/pi-subagents-notify.js",
      "extensions/pi-subagents-agent-sync.ts"
    ],
    "skills": [
      "skills"
    ]
  },
  "dependencies": {
    "pi-subagents": "^0.12.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "~0.66.1",
    "@mariozechner/pi-coding-agent": "~0.66.1",
    "@mariozechner/pi-tui": "~0.66.1",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mariozechner/pi-ai": "~0.66.1",
    "@mariozechner/pi-coding-agent": "~0.66.1",
    "@mariozechner/pi-tui": "~0.66.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
